---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";
import WidgetWrapper from "@/components/widgets/WidgetWrapper.astro";

const metadata = {
  title: "Price - 料金プラン",
  description:
    "メールコンサルティング、リモートコンサルティング、プレミアムコンサルティングの料金プランをご紹介します。",
};
---

<BaseLayout {metadata}>
  <!-- Hero Section -->
  <Content
    tagline="Price"
    title="料金プラン"
    description={[
      "お客様のニーズに合わせた、3つのコンサルティングプランをご用意しております。",
    ]}
  />

  <!-- Pricing Cards -->
  <WidgetWrapper containerClass="max-w-7xl mx-auto px-4 pt-0 md:pt-0">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      <!-- Plan 1: メールコンサルティング -->
      <div
        class="pricing-card group relative flex flex-col rounded-2xl border border-border/60 bg-card p-6 lg:p-8 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5"
      >
        <div class="mb-6">
          <span
            class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wider text-primary uppercase"
          >
            Mail
          </span>
        </div>
        <h3 class="text-xl font-bold tracking-tight mb-1">
          メールコンサルティング
        </h3>
        <p class="text-sm text-muted-foreground mb-4">回数報酬（税別）</p>
        <div class="mb-6">
          <span class="text-4xl font-extrabold tracking-tight">¥15,000</span>
          <span class="text-muted-foreground ml-1 text-sm">/ 回</span>
        </div>
        <div class="h-px bg-border/60 mb-6"></div>
        <p class="text-sm leading-relaxed text-muted-foreground mb-6 grow">
          新規事業にかかわる、質問などをメールにてコンサルティングを行うサービスです。お客様のお悩み事・質問などをメールにてご連絡をいただいたのち、それに対する返答をメールで差し上げるメールベースコンサルティングで、簡易的なコンサルティングプランです。
        </p>
        <ul class="space-y-3 text-sm mb-8">
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>メールによる回答</span>
          </li>
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>1通につき800〜1,000字程度</span>
          </li>
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>簡易コンサルティングプラン</span>
          </li>
        </ul>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-xl border border-border bg-transparent px-6 py-3 text-sm font-semibold transition-all duration-200 hover:bg-primary hover:text-white hover:border-primary"
        >
          お問い合わせ
        </a>
      </div>

      <!-- Plan 2: リモートコンサルティング（推奨） -->
      <div
        class="pricing-card pricing-card--featured group relative flex flex-col rounded-2xl border-2 border-primary bg-card p-6 lg:p-8 shadow-xl shadow-primary/10 transition-all duration-300 hover:shadow-2xl hover:shadow-primary/20 md:-translate-y-2"
      >
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
          <span
            class="inline-block rounded-full bg-primary px-4 py-1 text-xs font-bold tracking-wider text-white uppercase shadow-md"
          >
            おすすめ
          </span>
        </div>
        <div class="mb-6 mt-2">
          <span
            class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wider text-primary uppercase"
          >
            Remote
          </span>
        </div>
        <h3 class="text-xl font-bold tracking-tight mb-1">
          リモートコンサルティング
        </h3>
        <p class="text-sm text-muted-foreground mb-4">時間報酬（税別）</p>
        <div class="mb-6">
          <span class="text-4xl font-extrabold tracking-tight">¥30,000</span>
          <span class="text-muted-foreground ml-1 text-sm">/ 時間</span>
        </div>
        <div class="h-px bg-border/60 mb-6"></div>
        <p class="text-sm leading-relaxed text-muted-foreground mb-6 grow">
          100％リモート会議による、起業・新規事業等にかかわるコンサルティングです。ご相談内容についてはお客様のご要望に応じて対応いたします。リモート会議にて事前すり合わせを行った後に、100％リモートコンサルティング＋メンタリングを行うコンサルティングプランです。
        </p>
        <ul class="space-y-3 text-sm mb-8">
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>100％リモート会議</span>
          </li>
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>コンサルティング＋メンタリング</span>
          </li>
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>事前すり合わせ対応</span>
          </li>
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>単価 3.0万円/h</span>
          </li>
        </ul>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white shadow-md transition-all duration-200 hover:bg-primary/90 hover:shadow-lg"
        >
          お問い合わせ
        </a>
      </div>

      <!-- Plan 3: プレミアムコンサルティング -->
      <div
        class="pricing-card group relative flex flex-col rounded-2xl border border-border/60 bg-card p-6 lg:p-8 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5"
      >
        <div class="mb-6">
          <span
            class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wider text-primary uppercase"
          >
            Premium
          </span>
        </div>
        <h3 class="text-xl font-bold tracking-tight mb-1">
          プレミアムコンサルティング
        </h3>
        <p class="text-sm text-muted-foreground mb-4">時間報酬（税別）</p>
        <div class="mb-6">
          <span class="text-4xl font-extrabold tracking-tight">¥45,000</span>
          <span class="text-muted-foreground ml-1 text-sm">/ 時間</span>
        </div>
        <div class="h-px bg-border/60 mb-6"></div>
        <p class="text-sm leading-relaxed text-muted-foreground mb-6 grow">
          定期的なコンサルティングをご要望のお客様に対しては、顧問契約を締結の上、コンサルティングサービスを提供させていただきます。訪問コンサルティングを単価（4.5万円/h）で行い、訪問並びにメールなどでコンサルティング＋メンタリングにより解決策をご提示します。より高い成果を目指すためのコンサルティングプランです。
        </p>
        <ul class="space-y-3 text-sm mb-8">
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>訪問コンサルティング対応</span>
          </li>
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>顧問契約によるサポート</span>
          </li>
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>訪問＋メールでのメンタリング</span>
          </li>
          <li class="flex items-start gap-2">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>単価 4.5万円/h</span>
          </li>
        </ul>
        <p class="text-xs text-muted-foreground mb-4">
          ※
          お客様のご依頼内容によっては、コンサルティングサービスをお断りする場合がございます。
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-xl border border-border bg-transparent px-6 py-3 text-sm font-semibold transition-all duration-200 hover:bg-primary hover:text-white hover:border-primary"
        >
          お問い合わせ
        </a>
      </div>
    </div>
  </WidgetWrapper>

  <!-- 講演・セミナー -->
  <WidgetWrapper containerClass="max-w-5xl mx-auto px-4">
    <div class="rounded-2xl border border-border/60 bg-card p-8 lg:p-12">
      <div class="flex flex-col md:flex-row md:items-start gap-8">
        <div class="md:w-2/3">
          <div class="mb-4">
            <span
              class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wider text-primary uppercase"
            >
              Seminar
            </span>
          </div>
          <h3 class="text-2xl font-bold tracking-tight mb-4">講演・セミナー</h3>
          <p class="text-sm leading-relaxed text-muted-foreground mb-6">
            一回の講演・セミナーは最大2時間とし、内容と参加人数にもよっても異なりますが、<strong
              class="text-foreground">20〜50万円</strong
            >が目安になります。テーマや開催形式、開催期間等はご希望をお知らせください。事前にゆっくりとお話を聞かせていただき、必ず得るものがある内容を提供いたします。
          </p>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start gap-2">
              <svg
                class="mt-0.5 h-4 w-4 shrink-0 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>最大2時間 / 回</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="mt-0.5 h-4 w-4 shrink-0 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>テーマ・形式のカスタマイズ可能</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="mt-0.5 h-4 w-4 shrink-0 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>事前ヒアリングによるカスタマイズ</span>
            </li>
          </ul>
        </div>
        <div class="md:w-1/3">
          <div class="rounded-xl bg-muted/50 border border-border/40 p-6">
            <p class="text-sm font-semibold mb-1 text-muted-foreground">
              料金目安
            </p>
            <p class="text-3xl font-extrabold tracking-tight">
              20〜50<span class="text-lg">万円</span>
            </p>
            <p class="text-xs text-muted-foreground mt-1">
              内容・参加人数により変動
            </p>
          </div>
        </div>
      </div>
    </div>
  </WidgetWrapper>

  <!-- 配布用資料 -->
  <WidgetWrapper containerClass="max-w-5xl mx-auto px-4">
    <div class="rounded-2xl border border-border/60 bg-card p-8 lg:p-12">
      <div class="flex flex-col md:flex-row md:items-start gap-8">
        <div class="md:w-2/3">
          <div class="mb-4">
            <span
              class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wider text-primary uppercase"
            >
              Material
            </span>
          </div>
          <h3 class="text-2xl font-bold tracking-tight mb-4">配布用資料</h3>
          <p class="text-sm leading-relaxed text-muted-foreground mb-6">
            講演、セミナーなどで配布するプレゼン資料の制作費は、<strong
              class="text-foreground">基本料金1万円＋4,000円/ページ</strong
            >となります。
          </p>
          <div class="rounded-xl bg-muted/50 border border-border/40 p-5">
            <p class="text-sm font-semibold mb-3">
              料金例：10ページの資料の場合
            </p>
            <table class="w-full text-sm">
              <tbody>
                <tr class="border-b border-border/40">
                  <td class="py-2 text-muted-foreground">基本料金</td>
                  <td class="py-2 text-right font-medium">¥10,000</td>
                </tr>
                <tr class="border-b border-border/40">
                  <td class="py-2 text-muted-foreground"
                    >ページ制作費（¥4,000 × 10ページ）</td
                  >
                  <td class="py-2 text-right font-medium">¥40,000</td>
                </tr>
                <tr>
                  <td class="py-2 font-semibold">合計</td>
                  <td
                    class="py-2 text-right text-lg font-extrabold text-primary"
                    >¥50,000</td
                  >
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="md:w-1/3">
          <div class="rounded-xl bg-muted/50 border border-border/40 p-6">
            <p class="text-sm font-semibold mb-3 text-muted-foreground">
              料金体系
            </p>
            <div class="space-y-4">
              <div>
                <p class="text-xs text-muted-foreground">基本料金</p>
                <p class="text-2xl font-extrabold tracking-tight">¥10,000</p>
              </div>
              <div class="h-px bg-border/60"></div>
              <div>
                <p class="text-xs text-muted-foreground">ページ単価</p>
                <p class="text-2xl font-extrabold tracking-tight">
                  ¥4,000<span class="text-sm font-normal text-muted-foreground">
                    / ページ</span
                  >
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </WidgetWrapper>

  <!-- CTA Section -->
  <WidgetWrapper containerClass="max-w-3xl mx-auto px-4 text-center">
    <div
      class="rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/5 to-primary/10 p-8 lg:p-12"
    >
      <h3 class="text-2xl font-bold tracking-tight mb-3">
        まずはお気軽にご相談ください
      </h3>
      <p class="text-sm text-muted-foreground mb-6 max-w-lg mx-auto">
        お客様のご状況やご要望をお伺いした上で、最適なコンサルティングプランをご提案いたします。
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-xl bg-primary px-8 py-3.5 text-sm font-semibold text-white shadow-md transition-all duration-200 hover:bg-primary/90 hover:shadow-lg"
      >
        お問い合わせはこちら
        <svg
          class="ml-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </WidgetWrapper>
</BaseLayout>
