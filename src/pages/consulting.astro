---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";
import WidgetWrapper from "@/components/widgets/WidgetWrapper.astro";

import BizDevImg from "@/assets/images/10-image.webp";
import BizOptImg from "@/assets/images/2-image.webp";
import ConsulImg from "@/assets/images/1-image.webp";
import { Image } from "astro:assets";

const metadata = {
  title: "Consulting - コンサルティング",
  description:
    "新規事業・起業にかかわるコンサルティングサービス。成長の4段階、事業計画、事業戦略立案フレームワークをご紹介します。",
};

const consultingOverview = [
  {
    tag: "Growth",
    icon: `<svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>`,
    title: "Four Stages of Growth",
    titleJa: "成長の4段階",
    description:
      "新規事業を「探索 → 検証 → 実装 → スケール」の非連続プロセスとして捉える構造フレームワーク。",
  },
  {
    tag: "Plan",
    icon: `<svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    title: "Business Plan",
    titleJa: "事業計画",
    description:
      "戦略・モデル・実行の3階層を統合する意思決定モデルとしての事業計画を策定。",
  },
  {
    tag: "Strategy",
    icon: `<svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" /></svg>`,
    title: "Business Strategy Framework",
    titleJa: "ビジネス戦略フレームワーク",
    description:
      "外部環境・内部資源・提供価値・収益構造の4視点で事業を分解・再構築する中核フレームワーク。",
  },
];

const growthStages = [
  {
    number: "1",
    title: "Idea / Opportunity（構想・機会探索）",
    description:
      "市場構造・技術トレンド・未充足ニーズを起点に「勝てる仮説領域」を特定するフェーズ。",
  },
  {
    number: "2",
    title: "Validation（検証・PMF前段階）",
    description:
      "顧客インタビューやMVPを通じて「価値仮説」を検証するフェーズ。",
  },
  {
    number: "3",
    title: "Growth / Scale（成長・拡張）",
    description:
      "検証済みモデルをスケーラブルなオペレーションに転換するフェーズ。",
  },
  {
    number: "4",
    title: "Optimization（最適化・横展開）",
    description:
      "獲得した事業モデルを横展開・最適化し、成長曲線を最大化するフェーズ。",
  },
];

const businessPlanLayers = [
  {
    number: "1",
    title: "戦略レイヤー",
    description:
      "どの市場で戦うか（Where）、どの価値で勝つか（Why win）を定義する。",
    bullets: ["どの市場で戦うか（Where）", "どの価値で勝つか（Why win）"],
  },
  {
    number: "2",
    title: "モデルレイヤー",
    description: "収益化の仕組みと顧客・チャネル・価格設計を構築する。",
    bullets: [
      "どのように収益化するか（How make money）",
      "顧客・チャネル・価格設計",
    ],
  },
  {
    number: "3",
    title: "実行レイヤー",
    description: "具体的な実行計画とリソース配分を設計する。",
    bullets: [
      "いつ・誰が・何をやるか（Execution system）",
      "KPIとリソース配分",
    ],
  },
];

const frameworkPerspectives = [
  {
    number: "1",
    title: "External（外部環境）",
    bullets: ["マクロトレンド（PEST）", "業界構造（競争優位性）", "顧客変化"],
  },
  {
    number: "2",
    title: "Internal（内部資源）",
    bullets: ["アセット（技術・データ・組織）", "ケイパビリティ", "制約条件"],
  },
  {
    number: "3",
    title: "Value Proposition（提供価値）",
    bullets: ["顧客課題", "解決手段", "差別化要因"],
  },
  {
    number: "4",
    title: "Business Model（収益構造）",
    bullets: ["収益ドライバー（LTV / CAC）", "販売モデル", "スケーラビリティ"],
  },
];
---

<BaseLayout {metadata}>
  <!-- Page Header -->
  <Content
    tagline="Consulting"
    title="コンサルティング"
    description={[
      "新規事業・起業の成功を支えるための、包括的なコンサルティングサービスをご提供いたします。",
    ]}
  />

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- Overview Cards                               -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <WidgetWrapper containerClass="max-w-7xl mx-auto px-4 pt-0 md:pt-0">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {
        consultingOverview.map((item) => (
          <div class="group relative flex flex-col rounded-2xl border border-border/60 bg-card p-6 lg:p-8 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5">
            <div class="flex items-center gap-3 mb-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 transition-colors duration-200 group-hover:bg-primary group-hover:text-white">
                <span class="flex h-5 w-5" set:html={item.icon} />
              </div>
              <span class="inline-block text-xs font-semibold tracking-wider text-primary uppercase">
                {item.tag}
              </span>
            </div>
            <h3 class="text-lg font-bold tracking-tight mb-0.5">
              {item.title}
            </h3>
            <p class="text-sm font-medium text-primary/80 mb-3">
              {item.titleJa}
            </p>
            <p class="text-sm leading-relaxed text-muted-foreground grow">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </WidgetWrapper>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- Four Stages of Growth                       -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <WidgetWrapper id="growth" containerClass="max-w-6xl mx-auto px-4">
    <div class="rounded-2xl border border-border/60 bg-card p-8 lg:p-12">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
        <!-- Text Content -->
        <div class="lg:w-3/5">
          <!-- Section Header -->
          <div class="flex items-center gap-3 mb-6">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10"
            >
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"
                ></path>
              </svg>
            </div>
            <div>
              <span
                class="inline-block text-xs font-semibold tracking-wider text-primary uppercase"
                >Growth Model</span
              >
              <h2 class="text-2xl font-bold tracking-tight">
                Four Stages of Growth（成長の4段階）
              </h2>
            </div>
          </div>

          <p
            class="text-sm leading-relaxed text-muted-foreground mb-8 pl-0 md:pl-13"
          >
            このモデルは、新規事業を「探索 → 検証 → 実装 →
            スケール」の非連続プロセスとして捉える構造です。
          </p>

          <!-- Stage Items -->
          <div class="space-y-5">
            {
              growthStages.map((stage) => (
                <div class="flex gap-4 group">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-sm font-bold text-primary transition-colors duration-200 group-hover:bg-primary group-hover:text-white">
                    {stage.number}
                  </div>
                  <div class="pt-0.5">
                    <h3 class="text-base font-semibold mb-1">{stage.title}</h3>
                    <p class="text-sm leading-relaxed text-muted-foreground">
                      {stage.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Image -->
        <div class="lg:w-2/5 flex items-center">
          <div
            class="rounded-xl overflow-hidden border border-border/40 w-full"
          >
            <Image
              src={BizDevImg}
              alt="Business Development"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </div>
  </WidgetWrapper>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- Business Plan                               -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <WidgetWrapper id="plan" containerClass="max-w-6xl mx-auto px-4">
    <div class="rounded-2xl border border-border/60 bg-card p-8 lg:p-12">
      <div class="flex flex-col lg:flex-row-reverse gap-8 lg:gap-12">
        <!-- Text Content -->
        <div class="lg:w-3/5">
          <!-- Section Header -->
          <div class="flex items-center gap-3 mb-6">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10"
            >
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
                ></path>
              </svg>
            </div>
            <div>
              <span
                class="inline-block text-xs font-semibold tracking-wider text-primary uppercase"
                >Business Plan</span
              >
              <h2 class="text-2xl font-bold tracking-tight">
                事業計画の位置づけ
              </h2>
            </div>
          </div>

          <p
            class="text-sm leading-relaxed text-muted-foreground mb-8 pl-0 md:pl-13"
          >
            事業計画は単なる「数字の羅列」ではなく、以下の3階層を統合する意思決定モデルとして定義されます。
          </p>

          <!-- Layer Items -->
          <div class="space-y-6">
            {
              businessPlanLayers.map((layer) => (
                <div class="flex gap-4 group">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-sm font-bold text-primary transition-colors duration-200 group-hover:bg-primary group-hover:text-white">
                    {layer.number}
                  </div>
                  <div class="pt-0.5">
                    <h3 class="text-base font-semibold mb-1">{layer.title}</h3>
                    <p class="text-sm leading-relaxed text-muted-foreground mb-2">
                      {layer.description}
                    </p>
                    {layer.bullets && (
                      <ul class="space-y-1.5">
                        {layer.bullets.map((bullet: string) => (
                          <li class="flex items-start gap-2 text-sm text-muted-foreground">
                            <svg
                              class="mt-0.5 h-4 w-4 shrink-0 text-primary/70"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                              stroke-width="2.5"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M5 13l4 4L19 7"
                              />
                            </svg>
                            <span>{bullet}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Image -->
        <div class="lg:w-2/5 flex items-center">
          <div
            class="rounded-xl overflow-hidden border border-border/40 w-full"
          >
            <Image
              src={BizOptImg}
              alt="Business Optimization"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </div>
  </WidgetWrapper>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- Business Strategy Framework                  -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <WidgetWrapper id="framework" containerClass="max-w-6xl mx-auto px-4">
    <div class="rounded-2xl border border-border/60 bg-card p-8 lg:p-12">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
        <!-- Text Content -->
        <div class="lg:w-3/5">
          <!-- Section Header -->
          <div class="flex items-center gap-3 mb-6">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10"
            >
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"
                ></path>
              </svg>
            </div>
            <div>
              <span
                class="inline-block text-xs font-semibold tracking-wider text-primary uppercase"
                >Core Framework</span
              >
              <h2 class="text-2xl font-bold tracking-tight">
                事業戦略立案フレームワーク
              </h2>
            </div>
          </div>

          <p
            class="text-sm leading-relaxed text-muted-foreground mb-8 pl-0 md:pl-13"
          >
            このサービスの中核は、事業を以下の4視点で分解・再構築する構造です。
          </p>

          <!-- Perspective Items -->
          <div class="space-y-6">
            {
              frameworkPerspectives.map((item) => (
                <div class="flex gap-4 group">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-sm font-bold text-primary transition-colors duration-200 group-hover:bg-primary group-hover:text-white">
                    {item.number}
                  </div>
                  <div class="pt-0.5">
                    <h3 class="text-base font-semibold mb-2">{item.title}</h3>
                    <ul class="space-y-1.5">
                      {item.bullets.map((bullet: string) => (
                        <li class="flex items-start gap-2 text-sm text-muted-foreground">
                          <svg
                            class="mt-0.5 h-4 w-4 shrink-0 text-primary/70"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2.5"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M5 13l4 4L19 7"
                            />
                          </svg>
                          <span>{bullet}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Image -->
        <div class="lg:w-2/5 flex items-center">
          <div
            class="rounded-xl overflow-hidden border border-border/40 w-full"
          >
            <Image
              src={ConsulImg}
              alt="Startup Consulting"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </div>
  </WidgetWrapper>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- CTA Section                                  -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <WidgetWrapper containerClass="max-w-3xl mx-auto px-4 text-center">
    <div
      class="rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/5 to-primary/10 p-8 lg:p-12"
    >
      <h3 class="text-2xl font-bold tracking-tight mb-3">
        まずはお気軽にご相談ください
      </h3>
      <p class="text-sm text-muted-foreground mb-6 max-w-lg mx-auto">
        お客様の事業フェーズやご要望に合わせて、最適なコンサルティングプランをご提案いたします。
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-xl bg-primary px-8 py-3.5 text-sm font-semibold text-white shadow-md transition-all duration-200 hover:bg-primary/90 hover:shadow-lg"
        >
          お問い合わせはこちら
          <svg
            class="ml-2 h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href="/price"
          class="inline-flex items-center justify-center rounded-xl border border-border bg-transparent px-8 py-3.5 text-sm font-semibold transition-all duration-200 hover:bg-primary hover:text-white hover:border-primary"
        >
          料金プランを見る
        </a>
      </div>
    </div>
  </WidgetWrapper>
</BaseLayout>
