---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";

const metadata = {
  title: "Blog",
  description:
    "Future Trends Researchのリサーチ、事業開発、AI活用に関する記事を掲載しています。",
};

// ブログ記事ファイルを動的にロード
const posts = Object.values(
  import.meta.glob("../blog/*.md", { eager: true })
) as any[];

const categorySummaries: Record<string, string> = {
  Research: "未来技術、市場変化、産業構造を読み解くためのリサーチノート。",
  AI: "AIエージェント、生成AI、業務変革に関する実践的な観察記録。",
  Strategy: "シード期から成長期までの事業戦略、競争優位、ロードマップ設計。",
  Output: "リサーチや分析を、伝わる資料・提案・レポートへ変換する方法。",
  Analysis: "市場、顧客、競合、規制を構造化して読むための分析フレーム。",
  Discovery: "顧客課題、仮説検証、インタビュー設計に関する探索フェーズの記録。",
};

const categoryNames = ["Research", "AI", "Strategy", "Output", "Analysis", "Discovery"];

const categories = categoryNames.map((name) => {
  const notes = posts
    .filter((post) => post.frontmatter.category === name)
    .map((post) => ({
      title: post.frontmatter.title,
      // 表示用に "YYYY-MM-DD" を "YYYY.MM.DD" に変換
      date: post.frontmatter.date.replace(/-/g, "."),
      description: post.frontmatter.description,
      image: post.frontmatter.image,
      slug: post.frontmatter.slug,
      rawDate: post.frontmatter.date, // ソート用
    }))
    .sort((a, b) => b.rawDate.localeCompare(a.rawDate));

  return {
    name,
    summary: categorySummaries[name] || "",
    notes,
  };
});
---

<BaseLayout {metadata}>
  <Content
    tagline="Blog"
    title="Research Notes"
    description={[
      "未来技術、AI活用、事業開発、マーケットリサーチに関する知見を発信しています。",
    ]}
  />

  <section class="mx-auto mb-12 max-w-7xl px-4 md:mb-16">
    <div
      class="reveal mb-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-6"
      role="tablist"
      aria-label="Blog categories"
    >
      {
        categories.map((category, index) => (
          <button
            type="button"
            role="tab"
            id={`blog-tab-${category.name}`}
            aria-controls={`blog-panel-${category.name}`}
            aria-selected={index === 0 ? "true" : "false"}
            data-blog-tab={category.name}
            class:list={[
              "rounded-2xl border px-4 py-4 text-left transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary",
              index === 0
                ? "border-primary bg-primary text-white shadow-md"
                : "border-border bg-card text-foreground hover:border-primary/50",
            ]}
          >
            <span class="block text-sm font-bold">{category.name}</span>
            <span
              class:list={[
                "mt-1 block text-xs leading-5",
                index === 0 ? "text-white/80" : "text-muted-foreground",
              ]}
            >
              {category.notes.length} Notes
            </span>
          </button>
        ))
      }
    </div>

    {
      categories.map((category, index) => (
        <section
          id={`blog-panel-${category.name}`}
          aria-labelledby={`blog-tab-${category.name}`}
          data-blog-panel={category.name}
          class:list={[index !== 0 && "hidden"]}
          role="tabpanel"
        >
          <div class="reveal mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="mb-2 text-sm font-semibold text-primary">
                {category.name}
              </p>
              <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
                {category.name} Notes
              </h2>
            </div>
            <p class="max-w-2xl text-sm leading-7 text-muted-foreground">
              {category.summary}
            </p>
          </div>

          <div class="grid gap-6">
            {category.notes.map((note) => (
              <a
                href={`/blog/${note.slug}`}
                class="reveal group grid cursor-pointer overflow-hidden rounded-3xl border border-border bg-card shadow-sm transition-all hover:border-primary/50 hover:shadow-md md:grid-cols-[280px_1fr]"
              >
                <div class="overflow-hidden bg-muted/40">
                  <img
                    src={note.image}
                    alt=""
                    loading="lazy"
                    class="h-full min-h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105 md:aspect-auto"
                  />
                </div>
                <div class="flex flex-col p-6 md:p-8">
                  <div class="mb-4 flex flex-wrap items-center gap-3 text-sm">
                    <span class="rounded-full bg-primary/10 px-3 py-1 font-semibold text-primary">
                      {category.name}
                    </span>
                    <time class="text-muted-foreground">{note.date}</time>
                  </div>
                  <h3 class="mb-3 text-2xl font-bold tracking-tight text-foreground">
                    {note.title}
                  </h3>
                  <p class="mb-4 text-sm leading-7 text-muted-foreground">
                    {note.description}
                  </p>
                  <span class="mt-auto inline-flex items-center gap-1 text-sm font-medium text-primary transition-all group-hover:gap-2">
                    記事を読む
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </section>

  <script>
    const setupBlogTabs = () => {
      const tabs = Array.from(
        document.querySelectorAll<HTMLButtonElement>("[data-blog-tab]"),
      );
      const panels = Array.from(
        document.querySelectorAll<HTMLElement>("[data-blog-panel]"),
      );

      const activateCategory = (category: string) => {
        tabs.forEach((tab) => {
          const isActive = tab.dataset.blogTab === category;

          tab.setAttribute("aria-selected", String(isActive));
          tab.classList.toggle("border-primary", isActive);
          tab.classList.toggle("bg-primary", isActive);
          tab.classList.toggle("text-white", isActive);
          tab.classList.toggle("shadow-md", isActive);
          tab.classList.toggle("border-border", !isActive);
          tab.classList.toggle("bg-card", !isActive);
          tab.classList.toggle("text-foreground", !isActive);

          const noteCount = tab.querySelector("span:last-child");
          noteCount?.classList.toggle("text-white/80", isActive);
          noteCount?.classList.toggle("text-muted-foreground", !isActive);
        });

        panels.forEach((panel) => {
          panel.classList.toggle(
            "hidden",
            panel.dataset.blogPanel !== category,
          );
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const category = tab.dataset.blogTab;

          if (category) {
            activateCategory(category);
          }
        });
      });
    };

    document.addEventListener("astro:page-load", setupBlogTabs);
  </script>
</BaseLayout>
