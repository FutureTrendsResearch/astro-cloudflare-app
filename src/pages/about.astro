---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";
import WidgetWrapper from "@/components/widgets/WidgetWrapper.astro";
import { Image, getImage } from "astro:assets";
import visionImage from "@/assets/images/25-image.webp";

const metadata = {
  title: "About - 私たちについて",
  description:
    "Future Trends Researchのビジョン、バリュー、そして私たちの姿勢についてご紹介します。",
};

const values = [
  {
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
    title: "Innovation",
    description:
      "テクノロジーと市場構造の変化を捉え、既存産業の再定義につながる新たな事業機会を創出します。短期的な最適化ではなく、中長期の競争優位性を生み出すイノベーションを追求し、構想から社会実装までを一貫して支援します。",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" /></svg>`,
    title: "Commitment",
    description:
      "クライアントや投資先企業の成長に対して高い当事者意識を持ち、戦略立案だけで終わらない実行支援を重視します。不確実性の高い環境においても、本質的な課題解決に向き合い、持続的な企業価値向上にコミットします。",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>`,
    title: "Quality",
    description:
      "リサーチ、分析、戦略設計、実行支援のすべてにおいて高い品質基準を維持します。定量・定性の両面から構造的に課題を捉え、意思決定に資する実践的かつ再現性のあるアウトプットを提供します。",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    title: "Transparency",
    description:
      "情報・プロセス・意思決定の透明性を重視し、信頼に基づくパートナーシップを構築します。リスクや不確実性も含めて率直に共有し、オープンな対話を通じて最適な意思決定を支援します。",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    title: "Teamwork",
    description:
      "多様な専門性と視点を融合し、共創による価値最大化を目指します。クライアント、投資先、パートナーと密接に連携し、戦略と実行を横断する強固なチームワークを構築します。",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.023 6.023 0 01-2.77.672c-.992 0-1.929-.24-2.77-.672" /></svg>`,
    title: "Excellence",
    description:
      "常に高い視座と基準を持ち、卓越した成果の創出を追求します。市場環境が変化し続ける中でも、学習と進化を継続し、長期的なインパクトを生み出す存在であり続けます。",
  },
];

const optimizedImage = await getImage({
  src: visionImage,
  format: "png",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />

  <!-- Page Header -->
  <Content
    tagline="About"
    title="私たちについて"
    description={[
      "変化の激しい環境でも前進できる判断の軸を提供し、アイデアを確かな成長軌道に乗せる伴走者です。",
    ]}
  />

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- Vision                                       -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <WidgetWrapper
    id="vision"
    containerClass="max-w-6xl mx-auto px-4 pt-0 md:pt-0"
  >
    <div class="rounded-2xl border border-border/60 bg-card p-8 lg:p-12">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
        <!-- Text Content -->
        <div class="lg:w-3/5">
          <!-- Section Header -->
          <div class="flex items-center gap-3 mb-6">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10"
            >
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <span
                class="inline-block text-xs font-semibold tracking-wider text-primary uppercase"
                >Our Vision</span
              >
              <h2 class="text-2xl font-bold tracking-tight">ビジョン</h2>
            </div>
          </div>

          <div class="space-y-4 pl-0 md:pl-13">
            <p class="text-sm leading-relaxed text-muted-foreground">
              未来の不確実性を戦略と共創で可能性に変え、新規事業やシード段階の挑戦を構想から成長まで支える。変化の激しい環境でも前進できる判断の軸を提供し、アイデアを確かな成長軌道に乗せる伴走者として、社会の次のステージを共に開いていく。
            </p>
            <p class="text-sm leading-relaxed text-muted-foreground">
              現場の文脈を深く理解し、まだ形になっていない可能性を戦略と実践で具体化し、小さな一歩が大きな展開を生む循環をつくる。失敗を恐れず挑戦できる土壌を共に作り、持続的な成長の基盤を築く。
            </p>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col sm:flex-row gap-3 mt-8 pl-0 md:pl-13">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white shadow-md transition-all duration-200 hover:bg-primary/90 hover:shadow-lg"
            >
              <svg
                class="mr-2 h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                ></path>
              </svg>
              Contact Us
            </a>
            <a
              href="/consulting"
              class="inline-flex items-center justify-center rounded-xl border border-border bg-transparent px-6 py-3 text-sm font-semibold transition-all duration-200 hover:bg-primary hover:text-white hover:border-primary"
            >
              View Details
              <svg
                class="ml-2 h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Image -->
        <div class="lg:w-2/5 flex items-center">
          <div
            class="rounded-xl overflow-hidden border border-border/40 w-full"
          >
            <Image
              src={visionImage}
              alt="Our Vision"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </div>
  </WidgetWrapper>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- Our Values                                   -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <WidgetWrapper id="values" containerClass="max-w-6xl mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-10">
      <span
        class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wider text-primary uppercase mb-3"
      >
        Our Values
      </span>
      <h2 class="text-3xl font-bold tracking-tight mb-2">What Defines Us</h2>
      <p class="text-sm text-muted-foreground max-w-lg mx-auto">
        Principles that guide our daily work
      </p>
    </div>

    <!-- Values Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        values.map((value) => (
          <div class="group relative flex flex-col rounded-2xl border border-border/60 bg-card p-6 lg:p-8 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5">
            <div class="flex items-center gap-3 mb-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors duration-200 group-hover:bg-primary group-hover:text-white">
                <span class="flex h-5 w-5" set:html={value.icon} />
              </div>
              <h3 class="text-lg font-bold tracking-tight">{value.title}</h3>
            </div>
            <p class="text-sm leading-relaxed text-muted-foreground grow">
              {value.description}
            </p>
          </div>
        ))
      }
    </div>
  </WidgetWrapper>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- CTA Section                                  -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <WidgetWrapper containerClass="max-w-3xl mx-auto px-4 text-center">
    <div
      class="rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/5 to-primary/10 p-8 lg:p-12"
    >
      <h3 class="text-2xl font-bold tracking-tight mb-3">
        共に未来を創りましょう
      </h3>
      <p class="text-sm text-muted-foreground mb-6 max-w-lg mx-auto">
        私たちのビジョンに共感いただけましたら、ぜひお気軽にお問い合わせください。新規事業の構想段階から、成長フェーズまで伴走いたします。
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-xl bg-primary px-8 py-3.5 text-sm font-semibold text-white shadow-md transition-all duration-200 hover:bg-primary/90 hover:shadow-lg"
        >
          お問い合わせはこちら
          <svg
            class="ml-2 h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href="/consulting"
          class="inline-flex items-center justify-center rounded-xl border border-border bg-transparent px-8 py-3.5 text-sm font-semibold transition-all duration-200 hover:bg-primary hover:text-white hover:border-primary"
        >
          コンサルティングを見る
        </a>
      </div>
    </div>
  </WidgetWrapper>
</BaseLayout>
